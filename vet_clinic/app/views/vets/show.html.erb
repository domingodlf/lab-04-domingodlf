<h1 class="text-center my-4">Vet Details</h1>

<div class="container">
  <div class="card p-4 mb-4">
    <p><strong>Name:</strong> <%= @vet.first_name %> <%= @vet.last_name %></p>
    <p><strong>Email:</strong> <%= @vet.email %></p>
    <p><strong>Phone:</strong> <%= @vet.phone %></p>
    <p><strong>Specialization:</strong> <%= @vet.specialization %></p>
  </div>

  <h2 class="mb-3">Appointments</h2>

  <div class="table-responsive">
    <table class="table table-bordered table-striped text-center align-middle">
      <thead class="table-dark">
        <tr>
          <th>Date</th>
          <th>Pet</th>
          <th>Reason</th>
        </tr>
      </thead>
      <tbody>
        <% @vet.appointments.each do |appointment| %>
          <tr>
            <td><%= link_to appointment.date.strftime("%B %d, %Y"), appointment_path(appointment) %></td>
            <td><%= link_to appointment.pet.name, pet_path(appointment.pet) %></td>
            <td><%= appointment.reason %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>