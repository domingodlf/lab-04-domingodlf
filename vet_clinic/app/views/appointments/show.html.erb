<h1 class="text-center my-4">Appointment Details</h1>

<div class="container">
  <div class="card p-4 mb-4">
    <p><strong>Date:</strong> <%= @appointment.date.strftime("%B %d, %Y") if @appointment.date %></p>
    <p><strong>Reason:</strong> <%= @appointment.reason %></p>
    <p><strong>Status:</strong> <%= @appointment.status %></p>
    <p>
      <strong>Pet:</strong>
      <%= link_to @appointment.pet.name, pet_path(@appointment.pet) %>
    </p>
    <p>
      <strong>Vet:</strong>
      <%= link_to "#{@appointment.vet.first_name} #{@appointment.vet.last_name}", vet_path(@appointment.vet) %>
    </p>
  </div>

  <h2 class="mb-3">Treatments</h2>

  <div class="table-responsive">
    <table class="table table-bordered table-striped text-center align-middle">
      <thead class="table-dark">
        <tr>
          <th>Name</th>
          <th>Medication</th>
          <th>Dosage</th>
          <th>Administered at</th>
          <th>Notes</th>
        </tr>
      </thead>
      <tbody>
        <% @appointment.treatments.each do |treatment| %>
          <tr>
            <td><%= treatment.name %></td>
            <td><%= treatment.medication %></td>
            <td><%= treatment.dosage %></td>
            <td><%= treatment.administered_at.strftime("%B %d, %Y") if treatment.administered_at %></td>
            <td><%= treatment.notes %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>